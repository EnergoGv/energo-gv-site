* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background-color: #ffffff;
    color: #000000;
}

.nav {
    padding: 20px;
}

.nav a {
    margin-right: 16px;
    text-decoration: none;
    color: #1a0dab;
    font-weight: 500;
}

.container {
    max-width: 900px;
    margin: 120px auto 0;
    padding: 0 20px;
    text-align: center;
}

h1 {
    font-size: 48px;
    margin-bottom: 24px;
}

p {
    font-size: 18px;
    line-height: 1.6;
    margin-bottom: 40px;
    color: #555;
}

.button {
    display: inline-block;
    padding: 14px 28px;
    background-color: #2b6edc;
    color: #ffffff;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 500;
}

.button:hover {
    background-color: #1f56b3;
}