body {
  font-family: Arial, sans-serif;
  margin: 0;
  background-color: #f9f9f9;
}

.nav {
  padding: 20px 40px;
  background-color: #ffffff;
  border-bottom: 1px solid #eeeeee;
}

.nav a {
  margin-right: 20px;
  text-decoration: none;
  color: #333333;
  font-weight: 600;
}

.container {
  max-width: 900px;
  margin: 100px auto;
  padding: 0 20px;
  text-align: center;
}

h1 {
  font-size: 42px;
  margin-bottom: 20px;
}

h2 {
  font-size: 28px;
  margin-bottom: 20px;
}

p {
  font-size: 18px;
  line-height: 1.6;
  color: #555555;
  margin-bottom: 30px;
}

.button {
  display: inline-block;
  padding: 14px 28px;
  background-color: #2b6edc;
  color: #ffffff;
  text-decoration: none;
  border-radius: 8px;
  font-weight: 600;
}

.button:hover {
  background-color: #1f56b3;
}